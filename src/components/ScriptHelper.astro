---
// Helper interativo para scripts bash da documentação: campos com modo
// read/embutido/criptografado (age), toggles de heredoc e histórico, editor
// CodeMirror para o corpo e painel de saída com botão de copiar. Roda
// inteiramente no navegador — nenhum valor preenchido sai da página.
import type { ScriptField } from "./script-helper/types";
import {
    composeScript,
    initialFieldStates,
    validateFields,
} from "./script-helper/compose";

interface Props {
    /** Corpo do script: referencia apenas `$VAR`, sem linhas `read` nem `set -euo pipefail`. */
    script: string;
    fields?: ScriptField[];
    title?: string;
    /** Estado inicial do toggle `bash <<'EOF'`. */
    heredoc?: boolean;
    /** Exibe o toggle de desativar o histórico do bash (estado inicial: desligado). */
    historyToggle?: boolean;
    /** Habilita o modo criptografado (age) e a UI de chave pública. */
    encryption?: boolean;
    /** Emite `set -euo pipefail` no início do script. */
    strict?: boolean;
}

const {
    script,
    fields = [],
    title,
    heredoc = true,
    historyToggle = true,
    encryption = false,
    strict = true,
} = Astro.props;

validateFields(fields);

const defaultOutput = composeScript(script, initialFieldStates(fields), {
    heredoc,
    historyOff: false,
    strict,
    identityPath: "~/.config/age/keys.txt",
});

const uid = crypto.randomUUID().slice(0, 8);
const config = { script, fields, strict, encryption };
const configJson = JSON.stringify(config).replaceAll("<", "\\u003c");
---

<div class="script-helper" data-script-helper>
    {title && <p class="sh-title">{title}</p>}

    {
        fields.length > 0 && (
            <div class="sh-fields">
                {fields.map((f) => (
                    <div class="sh-field" data-field={f.var}>
                        <label for={`sh-${uid}-${f.var}`}>
                            {f.label} <code class="sh-var">${f.var}</code>
                        </label>
                        <div class="sh-field-row">
                            <input
                                id={`sh-${uid}-${f.var}`}
                                type={
                                    f.type === "password" ? "password" : "text"
                                }
                                data-field-input
                                placeholder={f.placeholder ?? ""}
                                value={f.defaultValue ?? ""}
                                disabled={(f.defaultMode ?? "read") === "read"}
                            />
                            <select
                                data-field-mode
                                aria-label={`Modo do campo ${f.label}`}
                            >
                                <option
                                    value="read"
                                    selected={
                                        (f.defaultMode ?? "read") === "read"
                                    }
                                >
                                    Perguntar ao executar (read)
                                </option>
                                <option
                                    value="inline"
                                    selected={f.defaultMode === "inline"}
                                >
                                    Embutir no script
                                </option>
                                {encryption && (
                                    <option
                                        value="encrypted"
                                        selected={f.defaultMode === "encrypted"}
                                    >
                                        Criptografar (age)
                                    </option>
                                )}
                            </select>
                        </div>
                        <p class="sh-warning" data-warning hidden />
                    </div>
                ))}
            </div>
        )
    }

    {
        encryption && (
            <div class="sh-crypto" data-crypto-box hidden>
                <div class="sh-field">
                    <label for={`sh-${uid}-recipient`}>
                        Chave pública age (recipient)
                    </label>
                    <textarea
                        id={`sh-${uid}-recipient`}
                        rows="2"
                        data-recipient
                        placeholder="age1..."
                    />
                </div>
                <div class="sh-field">
                    <label for={`sh-${uid}-identity`}>
                        Caminho da chave privada na máquina executora
                    </label>
                    <input
                        id={`sh-${uid}-identity`}
                        type="text"
                        data-identity
                        value="~/.config/age/keys.txt"
                    />
                </div>
                <p class="sh-hint">
                    Gere um par de chaves com{" "}
                    <code>age-keygen -o ~/.config/age/keys.txt</code> e cole
                    aqui a chave pública (<code>age1…</code>). A criptografia
                    acontece no seu navegador; para decodificar, a máquina que
                    executa o script precisa do CLI <code>age</code> e da chave
                    privada correspondente.
                </p>
                <p class="sh-warning" data-recipient-status hidden />
            </div>
        )
    }

    <div class="sh-toggles">
        <label>
            <input type="checkbox" data-toggle-heredoc checked={heredoc} />
            Envolver em <code>bash &lt;&lt;'EOF'</code>
        </label>
        {
            historyToggle && (
                <label>
                    <input type="checkbox" data-toggle-history />
                    Desativar histórico do bash (<code>set +o history</code>)
                </label>
            )
        }
    </div>

    <div class="sh-pane">
        <p class="sh-pane-title">Corpo do script (editável)</p>
        <div class="sh-editor" data-editor></div>
    </div>

    <div class="sh-pane">
        <div class="sh-pane-header">
            <p class="sh-pane-title">Script final (copie este)</p>
            <button type="button" class="sh-copy" data-copy
                >Copiar script</button
            >
            <span class="sh-copy-status" data-copy-status aria-live="polite"
            ></span>
        </div>
        <div class="sh-editor" data-output-editor></div>
        <pre
            class="sh-fallback"
            data-output-fallback><code>{defaultOutput}</code></pre>
    </div>

    <p class="sh-hint">
        Os valores preenchidos ficam só no seu navegador — nada é enviado para
        fora desta página. Leia o script gerado por completo antes de
        executá-lo.
    </p>

    <script
        type="application/json"
        data-config
        is:inline
        set:html={configJson}
    />
</div>

<noscript>
    <p>
        Com JavaScript desativado, os campos acima não funcionam; use o script
        exibido, que pergunta cada valor no terminal via <code>read</code>.
    </p>
</noscript>

<style>
    .script-helper {
        display: grid;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.5rem;
        background: var(--sl-color-gray-7);
    }
    .sh-title {
        margin: 0;
        font-weight: 600;
        color: var(--sl-color-white);
    }
    .sh-fields {
        display: grid;
        gap: 0.75rem;
    }
    .sh-field {
        display: grid;
        gap: 0.25rem;
    }
    .sh-field label {
        font-size: var(--sl-text-sm);
        color: var(--sl-color-gray-2);
    }
    .sh-var {
        font-size: var(--sl-text-xs);
        color: var(--sl-color-gray-3);
    }
    .sh-field-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .sh-field-row input {
        flex: 1 1 14rem;
    }
    .sh-field input,
    .sh-field textarea,
    .sh-field-row select {
        font: inherit;
        padding: 0.4rem 0.6rem;
        border-radius: 0.25rem;
        border: 1px solid var(--sl-color-gray-5);
        background: var(--sl-color-black);
        color: var(--sl-color-white);
    }
    .sh-field input:disabled {
        opacity: 0.5;
    }
    .sh-crypto {
        display: grid;
        gap: 0.75rem;
        padding: 0.75rem;
        border: 1px dashed var(--sl-color-gray-5);
        border-radius: 0.375rem;
    }
    .sh-toggles {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
    }
    .sh-toggles label {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: var(--sl-text-sm);
        color: var(--sl-color-gray-2);
    }
    .sh-pane {
        display: grid;
        gap: 0.375rem;
    }
    .sh-pane-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .sh-pane-title {
        margin: 0;
        font-size: var(--sl-text-sm);
        font-weight: 600;
        color: var(--sl-color-gray-2);
    }
    .sh-copy {
        font: inherit;
        font-size: var(--sl-text-sm);
        padding: 0.25rem 0.75rem;
        border-radius: 0.25rem;
        border: 1px solid var(--sl-color-gray-5);
        background: var(--sl-color-black);
        color: var(--sl-color-white);
        cursor: pointer;
    }
    .sh-copy:hover {
        border-color: var(--sl-color-gray-3);
    }
    .sh-copy-status {
        font-size: var(--sl-text-xs);
        color: var(--sl-color-green-high, var(--sl-color-gray-2));
    }
    .sh-warning {
        margin: 0;
        font-size: var(--sl-text-xs);
        color: var(--sl-color-orange-high, var(--sl-color-gray-2));
    }
    .sh-hint {
        margin: 0;
        font-size: var(--sl-text-xs);
        color: var(--sl-color-gray-3);
    }
    .sh-fallback {
        margin: 0;
        overflow-x: auto;
    }
</style>

<style is:global>
    /* Tokens de cor do CodeMirror: mapeiam a paleta do Starlight, que já troca
	   os valores conforme [data-theme], então claro/escuro resolve só com CSS. */
    .script-helper {
        --sh-cm-bg: var(--sl-color-black);
        --sh-cm-text: var(--sl-color-white);
        --sh-cm-keyword: var(--sl-color-text-accent);
        --sh-cm-atom: var(--sl-color-orange-high, #e0a06a);
        --sh-cm-string: var(--sl-color-green-high, #82d895);
        --sh-cm-string-special: var(--sl-color-purple-high, #b891f5);
        --sh-cm-comment: var(--sl-color-gray-3);
        --sh-cm-variable: var(--sl-color-blue-high, #83b4ff);
        --sh-cm-builtin: var(--sl-color-blue-high, #83b4ff);
    }
</style>

<script>
    import { initScriptHelpers } from "./script-helper/client";
    initScriptHelpers();
</script>
