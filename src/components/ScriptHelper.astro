---
// Helper interativo para scripts bash da documentação. A UI (React + shadcn)
// mostra o script final com botão de copiar; a engrenagem abre o modal de
// personalização (campos read/embutido/criptografado via age, toggles de
// heredoc e histórico, edição avançada do corpo). O output padrão é composto
// no build para servir de fallback antes da hidratação e sem JavaScript.
import type { ScriptField } from "./script-helper/types";
import {
    composeScript,
    initialFieldStates,
    validateFields,
} from "./script-helper/compose";
import ScriptHelperApp from "./script-helper/ScriptHelperApp";

interface Props {
    /** Corpo do script: referencia apenas `$VAR`, sem linhas `read` nem `set -euo pipefail`. */
    script: string;
    fields?: ScriptField[];
    title?: string;
    /** Estado inicial do toggle `bash <<'EOF'`. */
    heredoc?: boolean;
    /** Exibe o toggle de desativar o histórico do bash (estado inicial: desligado). */
    historyToggle?: boolean;
    /** Habilita o modo criptografado (age) e a UI de chave pública. */
    encryption?: boolean;
    /** Emite `set -euo pipefail` no início do script. */
    strict?: boolean;
}

const {
    script,
    fields = [],
    title,
    heredoc = true,
    historyToggle = true,
    encryption = false,
    strict = true,
} = Astro.props;

validateFields(fields);

const initialOutput = composeScript(script, initialFieldStates(fields), {
    shell: "bash",
    heredoc,
    historyOff: false,
    strict,
    identityPath: "~/.config/age/keys.txt",
});
---

<div class="script-helper not-content">
    <ScriptHelperApp
        client:load
        script={script}
        fields={fields}
        title={title}
        heredoc={heredoc}
        historyToggle={historyToggle}
        encryption={encryption}
        strict={strict}
        initialOutput={initialOutput}
    />
</div>

<noscript>
    <p>
        Com JavaScript desativado, a personalização não funciona; use o script
        exibido acima, que pergunta cada valor no terminal via <code>read</code
        >.
    </p>
</noscript>

<style>
    .script-helper {
        padding: 1rem;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.5rem;
        background: var(--sl-color-gray-7);
    }
</style>
