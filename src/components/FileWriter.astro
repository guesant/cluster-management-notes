---
import type { ScriptField } from "./script-helper/types";
import { prepareScriptHelper } from "./script-helper/prepare";
import { shellSingleQuote } from "./script-helper/compose";
import FileWriterApp from "./file-writer/FileWriterApp";

interface Props {
    path: string;
    content: string;
    script: string;
    owner: string;
    group: string;
    fields?: ScriptField[];
    title?: string;
    heredoc?: boolean;
    historyToggle?: boolean;
    encryption?: boolean;
    strict?: boolean;
    runUser?: string;
    runWhere?: string;
}

const {
    path,
    content,
    script,
    owner,
    group,
    fields = [],
    title,
    heredoc = true,
    historyToggle = true,
    encryption = false,
    strict = true,
    runUser,
    runWhere,
} = Astro.props;

const dir = path.slice(0, path.lastIndexOf("/")) || "/";
const scriptWithSetup = `mkdir -p ${shellSingleQuote(dir)}\nchown ${owner}:${group} ${shellSingleQuote(dir)}\n\n${script}`;

const { initialOutput, initialDisplay } = prepareScriptHelper(scriptWithSetup, fields, {
    heredoc,
    strict,
});
---

<div class="file-writer not-content">
    <FileWriterApp
        client:load
        path={path}
        dir={dir}
        owner={owner}
        group={group}
        content={content}
        script={scriptWithSetup}
        fields={fields}
        title={title}
        heredoc={heredoc}
        historyToggle={historyToggle}
        encryption={encryption}
        strict={strict}
        runUser={runUser}
        runWhere={runWhere}
        initialOutput={initialOutput}
        initialDisplay={initialDisplay}
    />
</div>

<noscript>
    <p>
        Com JavaScript desativado, a personalização não funciona; use o script
        exibido acima, que pergunta cada valor no terminal via <code>read</code
        >.
    </p>
</noscript>

<style>
    .file-writer {
        padding: 1rem;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.5rem;
        background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    }
</style>
