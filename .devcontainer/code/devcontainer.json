{
	"name": "infrastructure-and-cluster-notebook",
	"build": {
		"dockerfile": "../../.container/Dockerfile",
		"context": "../../.container",
		"target": "code"
	},
	"postCreateCommand": "bun install --frozen-lockfile",
	"forwardPorts": [4321],
	"portsAttributes": {
		"4321": {
			"label": "Astro dev server",
			"onAutoForward": "notify"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": ["astro-build.astro-vscode"]
		}
	}
}
